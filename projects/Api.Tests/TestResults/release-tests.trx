      FROM (&#xD;
          SELECT "c"."Id", "c"."AverageRentPerSqm", "c"."CountryCode", "c"."Latitude", "c"."Longitude", "c"."Name", "c"."Population"&#xD;
          FROM "Cities" AS "c"&#xD;
          LIMIT 1&#xD;
      ) AS "c1"&#xD;
      LEFT JOIN (&#xD;
          SELECT "c0"."Id", "c0"."Abundance", "c0"."CityId", "c0"."ResourceTypeId", "r"."Id" AS "Id0", "r"."BasePrice", "r"."Category", "r"."Description", "r"."ImageUrl", "r"."Name", "r"."Slug", "r"."UnitName", "r"."UnitSymbol", "r"."WeightPerUnit"&#xD;
          FROM "CityResources" AS "c0"&#xD;
          INNER JOIN "ResourceTypes" AS "r" ON "c0"."ResourceTypeId" = "r"."Id"&#xD;
      ) AS "s" ON "c1"."Id" = "s"."CityId"&#xD;
      ORDER BY "c1"."Id", "s"."Id"&#xD;
