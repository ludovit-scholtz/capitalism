{
  "ConnectionStrings": {
    "MasterCatalog": "Data Source=master.db"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5174"
    ]
  },
  "MasterServer": {
    "RegistrationKey": "local-master-registration-key",
    "ActiveThresholdSeconds": 90
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}